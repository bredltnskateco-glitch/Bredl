# Copy to `.env` (dev defaults) and `.env.production` (build defaults), then fill in.
# Both real files are gitignored — never commit secrets or environment-specific URLs.
#
# Reminder: Create React App only exposes variables prefixed with REACT_APP_*.
# Anything you put here is shipped in the public JS bundle — do not put server
# secrets (JWT_SECRET, MONGODB_URI, SMTP creds, Telegram tokens) in this file.
# Those live in server/.env and stay on the backend host.

# Backend API base URL (must include the /api suffix).
# Dev: blank → CRA proxy in package.json forwards /api/* to http://localhost:5000.
# Prod: full URL of the standalone backend, e.g. https://api.bredl.com/api
REACT_APP_API_URL=

# Google Sign-In OAuth 2.0 Client ID.
# Get one at https://console.cloud.google.com/apis/credentials.
# Authorized JavaScript origins: dev → http://localhost:3000, prod → your live domain.
REACT_APP_GOOGLE_CLIENT_ID=
